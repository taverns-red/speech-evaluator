{
  "name": "ai-speech-evaluator",
  "version": "0.6.24",
  "description": "AI Speech Evaluator MVP - captures live speech, transcribes, computes metrics, generates evaluation, and delivers via TTS",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp -r src/prompts dist/prompts",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "prepare": "husky"
  },
  "keywords": [
    "speech-evaluator",
    "speech-evaluation",
    "ai",
    "transcription",
    "tts"
  ],
  "license": "MIT",
  "dependencies": {
    "@clerk/express": "^2.0.6",
    "@deepgram/sdk": "^4.11.3",
    "@google-cloud/storage": "^7.19.0",
    "@tensorflow-models/blazeface": "^0.1.0",
    "@tensorflow-models/pose-detection": "^2.1.3",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.2",
    "fluent-ffmpeg": "^2.1.3",
    "http-proxy-middleware": "^3.0.5",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "openai": "^6.18.0",
    "pdf-parse": "^2.4.5",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@playwright/test": "^1.58.2",
    "@types/cookie": "^0.6.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/multer": "^2.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/sharp": "^0.31.1",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "fast-check": "^4.5.3",
    "husky": "^9.1.7",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "@tootallnate/once": "3.0.1"
  }
}
