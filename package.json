{
  "name": "ai-speech-evaluator",
  "version": "0.6.0",
  "description": "AI Speech Evaluator MVP - captures live speech, transcribes, computes metrics, generates evaluation, and delivers via TTS",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "keywords": [
    "speech-evaluator",
    "speech-evaluation",
    "ai",
    "transcription",
    "tts"
  ],
  "license": "MIT",
  "dependencies": {
    "@deepgram/sdk": "^4.11.3",
    "@tensorflow-models/blazeface": "^0.1.0",
    "@tensorflow-models/pose-detection": "^2.1.3",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^13.7.0",
    "fluent-ffmpeg": "^2.1.3",
    "multer": "^2.1.1",
    "openai": "^6.18.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/cookie": "^0.6.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/multer": "^2.0.0",
    "@types/sharp": "^0.31.1",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "fast-check": "^4.5.3",
    "husky": "^9.1.7",
    "vitest": "^4.0.18"
  }
}
